# 设置默认字符集
AddDefaultCharset UTF-8

# 开启重写引擎
# RewriteEngine On

# 如果请求的文件或目录存在，则直接访问
# RewriteCond %{REQUEST_FILENAME} !-f
# RewriteCond %{REQUEST_FILENAME} !-d

# 否则重写请求到index.php
# RewriteRule ^(.*)$ index.php [L]

# 保护上传目录不被直接访问
<Directory "./uploads">
    Options -Indexes
    <FilesMatch "\.(php|php[0-9])$">
        Deny from all
    </FilesMatch>
</Directory>

# 保护更新信息文件不被直接访问
<Files "update_info.json">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</Files>

# 自定义错误页面
# ErrorDocument 404 /404.html

# 增加PHP内存限制和执行时间
php_value memory_limit 256M
php_value max_execution_time 300

# 禁用PHP危险函数
php_flag allow_url_fopen off