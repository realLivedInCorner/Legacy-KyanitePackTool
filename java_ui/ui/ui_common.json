{
  "namespace": "common",

  "inventory_panel_bottom_half_with_label@inventory_panel_bottom_half": {
    "anchor_from": "bottom_left",
    "anchor_to": "bottom_left",
    "size": [ "100%", 93 ],
    "controls": [
      { "inventory_panel@inventory_panel": {} },
      {
        "inventory_label@section_heading_label": {
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "offset": [ 8, 1 ],
          "layer": 2,
          "text": "container.inventory"
        }
      }
    ]
  },

  "selected_item_details": {
    "controls": [
      {
        "item_panel_image": {
          "visible": false,
          "controls": [
            {
              "item_text_label": {
                "visible": false
              }
            }
          ]
        }
      }
    ]
  },

  "inventory_panel_bottom_half_with_low_label@inventory_panel_bottom_half": {
    "anchor_from": "bottom_left",
    "anchor_to": "bottom_left",
    "size": [ "100%", 93 ],
    "controls": [
      { "inventory_panel@inventory_panel": {} },
      {
        "inventory_label@section_heading_label": {
          "anchor_from": "top_left",
          "anchor_to": "top_left",
          "offset": [ 8, 2 ],
          "layer": 2,
          "text": "container.inventory"
        }
      }
    ]
  },

  "slot_selected": {
    "type": "image",
    "texture": "textures/ui/highlight_slot_1",
    "size": [ 16, 16 ],
    "$slot_selected_binding_name|default": "#is_selected_slot",
    "visible": false,
    "layer": 20,
    "bindings": [
      {
        "binding_name": "$slot_selected_binding_name",
        "binding_name_override": "#visible",
        "binding_type": "collection",
        "binding_collection_name": "$item_collection_name"
      }
    ]
  },
  "container_slot_button_prototype": {
    "pressed_control":"pressed",
    "controls": [
      {
        "hover@$highlight_control": {
        }
      },
      {
        "pressed@common.image_highlight_slot":{
        }
      },
      {
        "tooltip":{
          "type":"button",
          "consume_hover_events": false,
          "focus_enabled": false,
          "focus_magnet_enabled": false,
          "hover_control":"content",
          "controls":[
            {
              "always_follows_cursor":{
                "type":"button",
                "allow_clipping": false,
                "follows_cursor":true,//cnm的文档和ai都没说只有button能用这个啊
                "consume_hover_events": false,
                "always_handle_pointer": true,
                "focus_enabled": false,
                "focus_magnet_enabled": false,
                "controls":[
                  {
                    "content@fui.tooltip":{
                      
                    }
                  }
                ]
              }
            }
          ]
        }
      },
      {
        "bundle_popup_factory_control": {
          "type": "panel",
          "factory": {
            "name": "bundle_popup_factory",
            "control_name": "common.bundle_mode_popup_control",
            "max_children_size": 1
          }
        }
      }
    ]
  },
  "highlight_slot_panel": {
    "type": "panel",
    "controls": [
      {
        "highlight@common.highlight_slot": {
          "controls": [
            {
              "bundle_tooltip@common.bundle_tooltip": {
                "layer": 29,
                "$hover_text_binding_name|default": "#hover_text",
                "bindings": [
                  {
                    "binding_name": "$hover_text_binding_name",
                    "binding_name_override": "#hover_text",
                    "binding_type": "collection",
                    "binding_collection_name": "$item_collection_name"
                  },
                  {
                    "binding_name": "#hover_items_id",
                    "binding_name_override": "#hover_items_id",
                    "binding_type": "collection",
                    "binding_collection_name": "$item_collection_name"
                  }
                ]
              }
            }
          ],
          "bindings": [
            {
              "binding_name": "#show_persistent_bundle_hover_text",
              "binding_name_override": "#visible"
            }
          ]
        }
      }
    ]
  }
}