{

  "namespace": "fui",

  "empty":{},

  //触屏选中
  "cell_image_selected@common.image_highlight_slot": {
    "$cell_selected_binding_name|default": "#is_selected_slot",
    "visible": false,
    "bindings": [
      {
        "binding_name": "$cell_selected_binding_name",
        "binding_name_override": "#visible",
        "binding_type": "collection",
        "binding_collection_name": "$item_collection_name"
      }
    ]
  },

  //物品信息显示
  "tooltip_text":{
    "type":"label",
    "anchor_to":"top_left",
    "anchor_from":"center",
    "offset":[12,-12.5],
    "text":"$tooltip_hover_text",
    "$hover_text_binding_name|default": "#hover_text",
    "$tooltip_hover_text":"#hover_text",
    "shadow":true,
    "bindings": [
      {
        "binding_name": "$hover_text_binding_name",
        "binding_name_override": "#hover_text",
        "binding_type": "collection",
        "binding_collection_name": "$item_collection_name"
      },
      {
        "binding_name": "(not (#hover_text = ''))",
        "binding_name_override": "#visible",
        "binding_type": "collection",
        "binding_collection_name": "$item_collection_name"
      }
    ]
  },

  "tooltip":{
    "type":"panel",
    "layer":30,
    "controls":[
      {
        "text@fui.tooltip_text":{
          "layer":3
        }
      },
      {
        "background":{
          "type":"image",
          "anchor_to":"top_left",
          "anchor_from":"center",
          "texture":"textures/gui/sprites/tooltip/background",
          "size":["100%sm + 24px","100%sm + 22px"],
          "offset":[0,-23.5],
          "controls":[
            {
              "frame":{
                "type":"image",
                "texture":"textures/gui/sprites/tooltip/frame"
              }
            }
          ],
          "bindings": [
            {
              "binding_name": "(not (#hover_text = ''))",
              "binding_name_override": "#visible",
              "binding_type": "collection",
              "binding_collection_name": "$item_collection_name"
            }
          ]
        }
      }
    ]
  },

  //========//
  //  按钮  //
  //========//

  //特有的黑色背景按钮

  //按钮背景
  "button_addons_bg_default":{
    "type":"image",
    "texture":"textures/fui/button/bg_default",
    "size":"$button_bg_size"
  },

  "button_addons_bg_hover@fui.button_addons_bg_default":{
    "texture":"textures/fui/button/bg_hover"
  },

  "button_addons_bg_pressed@fui.button_addons_bg_default":{},

  "button_addons_content":{
    "type":"image",
    "size":[16,16],
    "texture":"$button_content_texture"
  },

  "button_addons_base@common.button":{
    "size":"$button_bg_size",

    //背景变量
    "$button_bg_size|default":[18,18],

    //按钮内容
    "$button_content_name|default":"empty",
    "$button_content_texture":"('textures/fui/button/content/' + $button_content_name)",

    "controls":[
      {"default@fui.button_addons_bg_default":{}},
      {"hover@fui.button_addons_bg_hover":{}},
      {"pressed@fui.button_addons_bg_pressed":{}},
      {"content@fui.button_addons_content":{}}
    ]
  },

  "button_close@button_addons_base":{
    "$button_content_name":"close",
    "$pressed_button_name": "button.menu_exit",
    "$button_tts_header|default": "accessibility.button.close"
  },

  
  //============//
  //  容器界面  //
  //============//

  //容器背景
  "container_background":{
    "type":"image",
    "texture":"$bg_texture",
    "size":"$bg_size",
    "alpha":"$bg_alpha"
  },

  //背包和快捷栏槽位
  "inventory_and_hotbar":{
    "type":"panel",
    "offset":"$inventory_offset",
    "size":	[0,0],
    "controls":[
      {"inventory@common.inventory_panel":{
        "offset":["100%","100% - 3px"],
        "$background_images": "fui.cell_image_selected"
      }},
      { "hotbar_grid@common.hotbar_grid_template": {
        "offset":["100%","100% - 7px"],
        "$background_images": "fui.cell_image_selected"
      } }
    ]
  },

  //容器侧边的按钮

  "container_side_addons_right@common.vertical_stack_panel":{
    "size":[0,0],
    "controls":[
      { "button_close@fui.button_close": {} },
      { "padding": {
        "type":"panel",
        "size":[2,2]
      } },
      { "addons@$right_addons": {} }
    ]
  },

  "container_side_addons":{
    "type":"panel",
    "offset":"$top_right_offset",
    "size":[0,0],
    "layer":11,
    "controls":[
      { "right@container_side_addons_right": {
        "offset":["100% + 2px","100% + 1px"]
      } }
    ]
  },

  //容器模块()
  "container_addons":{
    "type":"panel",
    "controls":[
      { "selected_item_details_factory@common.selected_item_details_factory": {} },
      { "item_lock_notification_factory@common.item_lock_notification_factory": {} },
      { "flying_item_renderer@common.flying_item_renderer": {} },
      { "inventory_selected_icon_button@common.inventory_selected_icon_button": {} },
      { "gamepad_cursor@common.gamepad_cursor_button": {} },
      { "side_addons@fui.container_side_addons": {} }
    ]
  },

  //容器界面
  "panel_container": {
    "type":"panel",

    "$top_half|default":"fui.empty",

    //配置界面背景图片
    "$bg_texture|default":"textures/gui/container/inventory",
    "$bg_size|default":[176,166],
    "$bg_alpha|default":1,

    //一些坐标配置
    "$top_right_offset|default":[88,-83],
    "$inventory_offset|default":[0,83],

    //侧边小按钮
    "$right_addons|default":"fui.empty",

    "controls":[
      //内容
      {"top_half@$top_half":{
        "layer":10
      }},
      //背包和物品栏格
      {"bottom_half@fui.inventory_and_hotbar":{
        "layer":10
      }},
      //背景
      {"bg@fui.container_background":{
        "layer":0
      }},
      {"addons@fui.container_addons":{}}
    ]
  }

}