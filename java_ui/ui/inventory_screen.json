{
  "namespace": "crafting",

  "crafting_label": {
    "type": "label",
    "anchor_from": "top_left",
    "anchor_to": "top_left",
    "text": "#crafting_label_text",
    "color": "$title_text_color",
    "layer": 11,
    "bindings": [
      {
        "binding_name": "#crafting_label_text"
      }
    ]
  },


  "layout_toggle@common_toggles.light_image_toggle": {
    "size": [ 15, 15 ],
    "$button_content": "crafting.layout_toggle_content",
    "$toggle_name": "layout_toggle",

    "$template_toggle": "crafting.layout_template_toggle",
    "$allow_controller_back_button_mapping": "$is_ps4",

    "$default_texture_alpha": 0,
    "$default_checked_texture_alpha": 0,
    "$hover_texture_alpha": 0,
    "$hover_checked_texture_alpha": 0
  },

  "layout_toggle_content": {
    "type": "panel",
    "controls": [
      {
        "icon@$icon_control": {
          "offset": [ 0, -3 ],
          "anchor_to": "top_middle",
          "anchor_from": "top_middle",

          "layer": 1
        }
      }
    ]
  },

  "inventory_icon": {
    "type": "image",
    "size": [ 15, 15 ],
    "texture": "textures/ui/inventory_icon"
  },

  "recipe_book_icon": {
    "type": "image",
    "size": [ 15, 15 ],
    "texture": "textures/ui/recipe_book_icon"
  },

  "creative_icon": {
    "type": "image",
    "size": [ 15, 15 ],
    "texture": "textures/ui/creative_icon"
  },

  "toolbar_background": {
    "type": "image",
    "texture": "textures/ui/Black"
  },

  "toolbar_panel@crafting.crafting_root_panel": {
    "size": [ "100%c", 20 ],

    "controls": [
      {
        "toolbar_background@crafting.toolbar_background": {
          "size": [ "100%cm", "100% + 8px" ],
          "offset": [ 0, -3 ],
          "anchor_from": "top_right",
          "anchor_to": "top_right",

          "controls": [
            {
              "toolbar_stack_panel": {
                "type": "stack_panel",
                "orientation": "vertical",

                "size": [ "default", "100% - 8px" ],
                "offset": [ 0, 21 ],
                "anchor_from": "top_middle",
                "anchor_to": "top_middle",

                "controls": [
                  {
                    "left_trigger_anchor": {
                      "type": "panel",
                      "size": [ 0, "100%" ],
                      "bindings": [
                        {
                          "binding_name": "#gamepad_helper_visible",
                          "binding_name_override": "#visible"
                        }
                      ],
                      "controls": [
                        {
                          "gamepad_helper_left_trigger@common.gamepad_helper_left_trigger": {
                            "offset": [ -5, -1 ],
                            "anchor_from": "left_middle",
                            "anchor_to": "left_middle"
                          }
                        }
                      ]
                    }
                  },
                  {
                    "padding_0": {
                      "type": "panel",
                      "size": [ 1, 1 ]
                    }
                  },
                  {
                    "close_button_panel": {
                      "type": "panel",
                      "size": [ 15, 15 ],
                      "bindings": [
                        {
                          "binding_name": "#close_button_visible",
                          "binding_name_override": "#visible"
                        }
                      ],
                      "controls": [
                        {
                          "close_button@common.close_button": {
                           "offset": [ 1, 2 ],
                            "anchor_from": "center",
                            "anchor_to": "center"
                          }
                        }
                      ]
                    }
                  },
                  {
                    "padding_1": {
                      "type": "panel",
                      "size": [ 1, 8 ],
                      "bindings": [
                        {
                          "binding_name": "#close_button_visible",
                          "binding_name_override": "#visible"
                        }
                      ]
                    }
                  },
                  {
                    "creative_layout_toggle_panel": {
                      "type": "panel",
                      "size": [15, 15 ],
                      "bindings": [
                        {
                          "binding_type": "global",
                          "binding_name": "#creative_layout_button_visible",
                          "binding_name_override": "#visible"
                        }
                      ],
                      "controls": [
                        {
                          "creative_layout_toggle@crafting.creative_layout_toggle": {
                            "$focus_override_left": "search_tab",
                            "offset":[1,0]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "padding_2": {
                      "type": "panel",
                      "size": [ 1, 1 ],
                      "bindings": [
                        {
                          "binding_type": "global",
                          "binding_name": "#creative_layout_button_visible",
                          "binding_name_override": "#visible"
                        }
                      ]
                    }
                  },
                  {
                    "recipe_book_layout_toggle_panel_survival": {
                      "type": "panel",
                      "size": [ 15, 15 ],
                      "bindings": [
                        {
                          "binding_type": "global",
                          "binding_name": "(not #is_creative_mode)",
                          "binding_name_override": "#visible"
                        }
                      ],
                      "controls": [
                        {
                          "recipe_book_layout_toggle@crafting.recipe_book_layout_toggle": {
                            "$focus_override_left": "search_tab",
                            "offset":[1,0]
                          }
                        }
                      ]
                    }
                  },
                  {
                    "recipe_book_layout_toggle_panel_creative": {
                      "type": "panel",
                      "size": [ 15, 15 ],
                      "bindings": [
                        {
                          "binding_type": "global",
                          "binding_name": "#is_creative_mode",
                          "binding_name_override": "#visible"
                        }
                      ],
                      "controls": [
                        { "recipe_book_layout_toggle@crafting.recipe_book_layout_toggle": {
                          "offset":[1,0]
                        } }
                      ]
                    }
                  },
                  {
                    "padding_3": {
                      "type": "panel",
                      "size": [ 1, 1 ]
                    }
                  },
                  {
                    "survival_layout_toggle_panel": {
                      "type": "panel",
                      "size": [ 15, 15 ],
                      "controls": [
                        { "survival_layout_toggle@crafting.survival_layout_toggle": {
                          "offset":[1,0]
                        } }
                      ]
                    }
                  },
                  {
                    "padding_4": {
                      "type": "panel",
                      "size": [ 1, 1 ]
                    }
                  },
                  {
                    "right_trigger_anchor": {
                      "type": "panel",
                      "size": [ 0, "100%" ],
                      "bindings": [
                        {
                          "binding_name": "#gamepad_helper_visible",
                          "binding_name_override": "#visible"
                        }
                      ],
                      "controls": [
                        {
                          "gamepad_helper_right_trigger@common.gamepad_helper_right_trigger": {
                            "offset": [ -5, 0 ],
                            "anchor_from": "right_middle",
                            "anchor_to": "left_middle"
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ]
  },
      
  "left_tab@common_tabs.tab_left": {
    "$toggle_focus_enabled": false,
    "$toggle_name": "navigation_tab",
    "$toggle_group_default_selected": "$construction_index",
    "$tab_content": "crafting.empty_tab_panel",
    "$unchecked_default_image": "textures/ui/TabLeftFront",
    "$unchecked_hover_image": "textures/ui/TabLeftFrontHover",
    "$unchecked_locked_image": "textures/ui/TabLeftFront",
    "$unchecked_locked_hover_image": "textures/ui/TabLeftFront",
    "$checked_default_image": "textures/ui/TabLeftFront",
    "$checked_hover_image": "textures/ui/TabLeftFrontHover",
    "$checked_locked_image": "textures/ui/TabLeftFrontHover",
    "$checked_locked_hover_image": "textures/ui/TabLeftFrontHover"
  },

  "search_tab_left@crafting.left_tab": {
    "$is_top_most_tab": false,
    "$tab_view_binding_name": "search_tab_toggle",
    "$tab_icon": "crafting.search_icon",
    "$toggle_group_forced_index": "$search_index",
    "$toggle_binding_type": "global",
    "$toggle_state_binding_name": "#is_left_tab_search",
    "$focus_id": "search_tab",
    "$focus_override_down": "equipment_tab",
    "$focus_override_left": "FOCUS_OVERRIDE_STOP"
  },

  "construction_tab_left@crafting.left_tab": {
    "$tab_view_binding_name": "construction_tab_toggle",
    "$tab_icon": "crafting.construction_icon",
    "$toggle_group_forced_index": "$construction_index",
    "$toggle_binding_type": "global",
    "$toggle_state_binding_name": "#is_left_tab_construct",
    "$focus_id": "construction_tab",
    "$focus_override_left": "FOCUS_OVERRIDE_STOP",
    "$focus_override_down": "nature_tab",
    "$focus_override_up": "equipment_tab"
  },

  "equipment_tab_left@crafting.left_tab": {
    "$tab_view_binding_name": "equipment_tab_toggle",
    "$tab_icon": "crafting.equipment_icon",
    "$toggle_group_forced_index": "$equipment_index",
    "$toggle_binding_type": "global",
    "$toggle_state_binding_name": "#is_left_tab_equipment",
    "$focus_id": "equipment_tab",
    "$focus_override_left": "FOCUS_OVERRIDE_STOP",
    "$focus_override_up": "search_tab",
    "$focus_override_down": "construction_tab"
  },

  "nature_tab_left@crafting.left_tab": {
    "$tab_view_binding_name": "nature_tab_toggle",
    "$tab_icon": "crafting.nature_icon",
    "$toggle_group_forced_index": "$nature_index",
    "$toggle_binding_type": "global",
    "$toggle_state_binding_name": "#is_left_tab_nature",
    "$focus_id": "nature_tab",
    "$focus_override_left": "FOCUS_OVERRIDE_STOP",
    "$focus_override_up": "construction_tab",
    "$focus_override_down": "item_tab"
  },

  "items_tab_left@crafting.left_tab": {
    "$tab_view_binding_name": "items_tab_toggle",
    "$tab_icon": "crafting.miscellaneous_icon",
    "$toggle_group_forced_index": "$items_index",
    "$toggle_binding_type": "global",
    "$toggle_state_binding_name": "#is_left_tab_items",
    "$focus_id": "items_tab",
    "$focus_override_left": "FOCUS_OVERRIDE_STOP",
    "$focus_override_up": "nature_tab"
  },

  

  "left_tab_navigation_panel_layout": {
    "type": "stack_panel",
    "orientation": "vertical",
    "anchor_to": "left",
    "anchor_from": "left",
    "size": [ 29, 23 ],
    "controls": [
     {
        "search_tab@crafting.search_tab_left": {
          "size": [ 29, 23 ]
        }
      },
      {
        "empty_panel_0": {
        "type": "panel",
        "size": [ "fill", 1 ]
        }
      },
      {
        "equipment_tab@crafting.equipment_tab_left": {
          "size": [ 29, 23 ]
        }
      },
      {
        "empty_panel_1": {
        "type": "panel",
        "size": [ "fill", 1 ]
        }
      },
      {
        "construction_tab@crafting.construction_tab_left": {
          "size": [ 29, 23 ]
        }
      },
      {
        "empty_panel_2": {
        "type": "panel",
        "size": [ "fill", 1 ]
        }
      },
      {
        "nature_tab@crafting.nature_tab_left": {
          "size": [ 29, 23 ]
        }
      },
      {
        "empty_panel_3": {
        "type": "panel",
        "size": [ "fill", 1 ]
        }
      },
      {
        "items_tab@crafting.items_tab_left": {
          "size": [ 29, 23 ]
        }
      }
    ]
  },

  "scroll_grid_panel@crafting.crafting_root_panel": {
    "type": "input_panel",
    "size": [ "100%", "100%c + 2px" ],
    "controls": [
      { "grid@crafting.scroll_grid": {} }
    ]
  },
  "tab_navigation_panel_layout": {
    "type": "stack_panel",
    "orientation": "horizontal",
    "size": [ "100%", 27 ],
    "ttsSectionContainer": true,
    "$is_search_right_most_tab|default": true,
    "controls": [
      {
        "navigation_tabs": {
          "type": "panel",
          "size": [ "fill", "100%" ],
          "controls": [
            {
              "content": {
                "type": "stack_panel",
                "orientation": "horizontal",
                "size": [ "100%", "100% + 4px" ],
                "anchor_to": "top_left",
                "anchor_from": "top_left",
                "controls": [
                  {
                    "construction_tab_panel": {
                      "type": "panel",
                      "size": [ 25, "100%" ],
                      "$is_left_most_tab": true,
                      "controls": [
                        {
                          "construction_tab_factory": {
                            "type": "factory",
                            "control_ids": {
                              "construction_tab": "@crafting.construction_tab"
                            }
                          }
                        }
                      ]
                    }
                  },
                  {
                    "equipment_tab_panel": {
                      "type": "panel",
                      "size": [ 25, "100%" ],
                      "controls": [
                        {
                          "equipment_tab_factory": {
                            "type": "factory",
                            "control_ids": {
                              "equipment_tab": "@crafting.equipment_tab"
                            }
                          }
                        }
                      ]
                    }
                  },
                  {
                    "items_tab_panel": {
                      "type": "panel",
                      "size": [ 25, "100%" ],
                      "controls": [
                        {
                          "items_tab_factory": {
                            "type": "factory",
                            "control_ids": {
                              "items_tab": "@crafting.items_tab"
                            }
                          }
                        }
                      ]
                    }
                  },
                  {
                    "nature_tab_panel": {
                      "type": "panel",
                      "size": [ 25, "100%" ],
                      "controls": [
                        {
                          "nature_tab_factory": {
                            "type": "factory",
                            "control_ids": {
                              "nature_tab": "@crafting.nature_tab"
                            }
                          }
                        }
                      ]
                    }
                  },
                  {
                    "fill_panel_0": {
                      "type": "panel",
                      "size": [ "fill", "100%" ]
                    }
                  },
                  {
                    "search_tab_holder": {
                      "type": "panel",
                      "size": [ 25, "100%" ],
                      "controls": [
                        {
                          "search_tab_end_creative@crafting.search_tab": {
                            "$focus_override_right": "creative_layout_toggle",

                            "bindings": [
                              {
                                "binding_type": "global",
                                "binding_name": "#is_creative_and_recipe_book_layout",
                                "binding_name_override": "#visible"
                              }
                            ]
                          }
                        },
                        {
                          "search_tab_creative@crafting.search_tab": {
                            "$is_right_most_tab": false,
                            "$focus_override_right": "creative_layout_toggle",

                            "bindings": [
                              {
                                "binding_type": "global",
                                "binding_name": "#is_creative_and_creative_layout",
                                "binding_name_override": "#visible"
                              }
                            ]
                          }
                        },
                        {
                          "search_tab_survival@crafting.search_tab": {
                            "$focus_override_right": "recipe_book_layout_toggle",

                            "bindings": [
                              {
                                "binding_type": "global",
                                "binding_name": "(not #is_creative_mode)",
                                "binding_name_override": "#visible"
                              }
                            ]
                          }
                        }
                      ]
                    }
                  }
                ]
              }
            }
          ]
        }
      }
    ],
    "bindings": [
      {
        "binding_type": "global",
        "binding_name": "#is_creative_layout",
        "binding_name_override": "#visible"
      }
    ]
  },
